# Auto detect text files and normalize line endings to LF
* text=auto

# JavaScript/TypeScript
*.js eol=lf
*.ts eol=lf
*.tsx eol=lf
*.jsx eol=lf
*.json eol=lf

# Shell scripts
*.sh eol=lf

# Windows specific
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Lockfiles
package-lock.json eol=lf
pnpm-lock.yaml eol=lf
yarn.lock eol=lf
